DATABASE_URL="postgresql://meru:meru_secret@localhost:5432/meru_tour?schema=public"
JWT_SECRET="change-me-in-production-meru-tour-secret-key"
JWT_EXPIRES_IN="7d"
PORT=4000
FRONTEND_URL="http://localhost:3000"
API_PUBLIC_URL="http://localhost:4000"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Optional SMTP for verification / password reset / booking emails
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="hello@merutour.com"

# Dev: confirm bookings without Stripe when NODE_ENV !== production (default true)
ALLOW_DEV_PAYMENT_CONFIRM="true"

# External hotel offer cache TTL is 24h; extended on each hotel detail view
# HOTEL_OFFER_TTL_HOURS=24

# Amadeus for Developers — https://developers.amadeus.com
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_ENV="test"
AMADEUS_CURRENCY="USD"

# Skyscanner Travel API — https://developers.skyscanner.net
SKYSCANNER_API_KEY=""
SKYSCANNER_MARKET="US"
SKYSCANNER_LOCALE="en-US"
SKYSCANNER_CURRENCY="USD"

# Booking.com Demand API — https://developers.booking.com/demand
BOOKING_API_KEY=""
BOOKING_AFFILIATE_ID=""
BOOKING_ENV="sandbox"
BOOKING_CURRENCY="USD"
BOOKING_BOOKER_COUNTRY="us"
BOOKING_SEARCH_RADIUS_KM=25

# Expedia Rapid API — https://developers.expediagroup.com/rapid
EXPEDIA_RAPID_API_KEY=""
EXPEDIA_RAPID_API_SECRET=""
EXPEDIA_RAPID_ENV="test"
EXPEDIA_RAPID_CURRENCY="USD"
EXPEDIA_RAPID_LOCALE="en-US"
EXPEDIA_SEARCH_RADIUS_KM=25
EXPEDIA_TEST_PROPERTY_IDS="19248,20167"

# Google Maps Platform — https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACES_RADIUS_M=5000
